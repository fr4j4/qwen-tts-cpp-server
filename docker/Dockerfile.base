# Base image: CUDA toolkit + build dependencies.
# This image is built once and cached. It does NOT clone or build anything.
# Rebuild only when dependencies change.
#
# Usage:
#   docker build -f docker/Dockerfile.base -t qwen-tts-base:cuda12.6 .
FROM nvidia/cuda:12.6.0-devel-ubuntu24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    cmake g++ git python3 python3-venv python3-pip ffmpeg \
    libopenblas-dev wget ca-certificates curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Pre-create venv with Python deps so they're cached too
RUN python3 -m venv .venv \
    && .venv/bin/pip install --no-cache-dir fastapi uvicorn httpx pydantic